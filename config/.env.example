# Zabbix MCP Server Configuration

# ========== 共用配置 ==========
# Required: Zabbix server URL
ZABBIX_URL=https://zabbix.example.com

# Authentication Method 1: API Token (recommended)
ZABBIX_TOKEN=<your_api_token>

# Authentication Method 2: Username/Password (alternative to token)
# ZABBIX_USER=<username>
# ZABBIX_PASSWORD=<password>

# SSL Configuration
# VERIFY_SSL - Enable/disable SSL certificate verification (default: true)
# Set to false, 0, or no to disable SSL verification (not recommended for production)
VERIFY_SSL=true

# Debug logging
DEBUG=false

# ========== 只读服务器配置 ==========
# READONLY_TRANSPORT - Transport type: stdio (default) or streamable-http
READONLY_TRANSPORT=stdio

# HTTP Transport Configuration (only used when READONLY_TRANSPORT=streamable-http)
READONLY_HOST=0.0.0.0
READONLY_PORT=9002
READONLY_STATELESS_HTTP=false
READONLY_MOUNTPATH="/"

# Authentication type for HTTP transport
# Available options:
#   - no-auth: No authentication (default, recommended for local use)
#   - static-token: Static token authentication (use *_STATIC_TOKENS)
#   - jwt: JWT token authentication (use *_JWT_* settings)
READONLY_AUTH_TYPE=no-auth

# Static Token Authentication (when READONLY_AUTH_TYPE=static-token)
# JSON format: {"token1": {"client_id": "client1", "scopes": ["read"]}, "token2": ...}
# READONLY_STATIC_TOKENS={"my-secret-token": {"client_id": "my-client", "scopes": []}}

# JWT Authentication (when READONLY_AUTH_TYPE=jwt)
# Either JWT_PUBLIC_KEY or JWT_JWKS_URI is required
# READONLY_JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
# READONLY_JWT_JWKS_URI=https://auth.example.com/.well-known/jwks.json
# READONLY_JWT_ISSUER=https://auth.example.com
# READONLY_JWT_AUDIENCE=zabbix-mcp
# READONLY_JWT_ALGORITHM=RS256
# READONLY_JWT_REQUIRED_SCOPES=read:zabbix

# ========== 写入服务器配置 ==========
# WRITABLE_TRANSPORT - Transport type: stdio (default) or streamable-http
WRITABLE_TRANSPORT=stdio

# HTTP Transport Configuration (only used when WRITABLE_TRANSPORT=streamable-http)
WRITABLE_HOST=0.0.0.0
WRITABLE_PORT=9003
WRITABLE_STATELESS_HTTP=false
WRITABLE_MOUNTPATH="/"

# Authentication type for HTTP transport
# Available options:
#   - no-auth: No authentication (default, recommended for local use)
#   - static-token: Static token authentication (use *_STATIC_TOKENS)
#   - jwt: JWT token authentication (use *_JWT_* settings)
WRITABLE_AUTH_TYPE=no-auth

# Static Token Authentication (when WRITABLE_AUTH_TYPE=static-token)
# WRITABLE_STATIC_TOKENS={"my-secret-token": {"client_id": "my-client", "scopes": []}}

# JWT Authentication (when WRITABLE_AUTH_TYPE=jwt)
# Either JWT_PUBLIC_KEY or JWT_JWKS_URI is required
# WRITABLE_JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
# WRITABLE_JWT_JWKS_URI=https://auth.example.com/.well-known/jwks.json
# WRITABLE_JWT_ISSUER=https://auth.example.com
# WRITABLE_JWT_AUDIENCE=zabbix-mcp
# WRITABLE_JWT_ALGORITHM=RS256
# WRITABLE_JWT_REQUIRED_SCOPES=write:zabbix
